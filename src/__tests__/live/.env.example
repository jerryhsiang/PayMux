# Private key of a funded test wallet (hex string with 0x prefix)
# DO NOT commit real private keys to git!
TEST_PRIVATE_KEY=0x

# For mainnet tests — the wallet above must have USDC on Base mainnet
# For testnet tests — get free USDC from Base Sepolia faucet

# Optional: custom x402 endpoint to test against
# Default: uses a known public x402 endpoint
TEST_X402_ENDPOINT=

# Optional: custom MPP endpoint to test against
TEST_MPP_ENDPOINT=

# MPP server secret key (for running the server side of MPP tests)
TEST_MPP_SECRET_KEY=
