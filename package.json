{
  "name": "paymux",
  "version": "0.1.1",
  "description": "The easiest way to make your API agent-payable. Multi-protocol payment routing for AI agents.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "ai-agent",
    "payments",
    "mpp",
    "x402",
    "micropayments",
    "stripe",
    "coinbase",
    "agent-payments",
    "payment-routing",
    "agentic-commerce"
  ],
  "author": "Jerry Hsiang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerryhsiang/PayMux.git"
  },
  "bugs": {
    "url": "https://github.com/jerryhsiang/PayMux/issues"
  },
  "homepage": "https://paymux.dev",
  "peerDependencies": {
    "@x402/core": ">=2.0.0",
    "@x402/evm": ">=2.0.0",
    "express": ">=4.0.0",
    "hono": ">=4.0.0",
    "mppx": ">=0.1.0",
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@x402/core": {
      "optional": true
    },
    "@x402/evm": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "mppx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@x402/core": "^2.7.0",
    "@x402/evm": "^2.7.0",
    "express": "^5.1.0",
    "hono": "^4.6.0",
    "mppx": "^0.4.8",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "viem": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
